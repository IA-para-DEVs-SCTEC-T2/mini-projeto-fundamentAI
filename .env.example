# ============================================================
# FundamentAI - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# ============================================================

# --- Anthropic API ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Banco de Dados ---
# SQLite (desenvolvimento local) - não precisa alterar
DATABASE_URL=sqlite:///./fundamentai.db

# PostgreSQL (produção) - descomente e configure
# DATABASE_URL=postgresql://user:password@host:5432/fundamentai

# --- Ambiente ---
ENVIRONMENT=development  # development | production

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- ETL ---
# Horário de execução do ETL diário (após fechamento do mercado B3 às 18h)
ETL_SCHEDULE_HOUR=19
ETL_SCHEDULE_MINUTE=0
