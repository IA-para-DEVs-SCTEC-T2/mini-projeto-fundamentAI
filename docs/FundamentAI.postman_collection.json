{
  "info": {
    "name": "FundamentAI API",
    "description": "Coleção de testes de integração para a API do FundamentAI.\n\nCobre todos os endpoints disponíveis:\n- Health check\n- GET /api/ticker/{ticker} — ações e FIIs\n- POST /api/analysis/{ticker} — análise via LLM\n\n**Pré-requisito:** backend rodando em http://localhost:8000\n```\nuvicorn backend.api.main:app --reload --host 0.0.0.0 --port 8000\n```",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "fundamentai-api-v1"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "URL base da API. Altere para o endereço de produção quando necessário."
    }
  ],
  "item": [
    {
      "name": "Health & Root",
      "description": "Endpoints de status e navegação da API.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Verifica se a API está operacional. Retorna status e versão."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status = ok', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql('ok');",
                  "    pm.expect(body).to.have.property('version');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\",\n  \"version\": \"0.1.0\",\n  \"service\": \"FundamentAI API\"\n}"
            }
          ]
        },
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Endpoint raiz — retorna links de navegação."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tem link para docs', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('docs');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Swagger UI (docs)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/docs",
              "host": ["{{base_url}}"],
              "path": ["docs"]
            },
            "description": "Documentação interativa Swagger UI."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Docs disponíveis (200)', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Ticker — Ações",
      "description": "Consulta de dados fundamentalistas de ações da B3.\n\nFonte: fundamentus (indicadores) + yfinance (cotação e histórico).",
      "item": [
        {
          "name": "GET Ação — PETR4 (Petrobras)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/ticker/PETR4",
              "host": ["{{base_url}}"],
              "path": ["api", "ticker", "PETR4"]
            },
            "description": "Consulta dados fundamentalistas da Petrobras (PETR4).\n\nEspera:\n- asset_type = stock\n- score entre 0 e 100\n- indicadores de ação (roe, pe_ratio, net_margin, etc.)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Estrutura da resposta', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('ticker');",
                  "    pm.expect(body).to.have.property('asset_type');",
                  "    pm.expect(body).to.have.property('quote');",
                  "    pm.expect(body).to.have.property('indicators');",
                  "    pm.expect(body).to.have.property('score');",
                  "});",
                  "",
                  "pm.test('asset_type = stock', () => {",
                  "    pm.expect(pm.response.json().asset_type).to.eql('stock');",
                  "});",
                  "",
                  "pm.test('Score entre 0 e 100', () => {",
                  "    const score = pm.response.json().score.score;",
                  "    pm.expect(score).to.be.within(0, 100);",
                  "});",
                  "",
                  "pm.test('Score tem label válido', () => {",
                  "    const label = pm.response.json().score.label;",
                  "    pm.expect(['Excelente', 'Bom', 'Regular', 'Fraco']).to.include(label);",
                  "});",
                  "",
                  "// Salva ticker para uso em outros testes",
                  "pm.collectionVariables.set('last_stock_ticker', pm.response.json().ticker);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET Ação — VALE3 (Vale)",
