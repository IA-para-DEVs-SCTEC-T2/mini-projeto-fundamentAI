    {
      "name": "Analysis — LLM",
      "description": "Geração de análises fundamentalistas via Anthropic Claude.\n\n**Nota:** Requer ANTHROPIC_API_KEY configurada no .env.\nSem a chave, a API retorna um mock estruturado (comportamento de fallback).",
      "item": [
        {
          "name": "POST Analysis — PETR4",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/analysis/PETR4",
              "host": ["{{base_url}}"],
              "path": ["api", "analysis", "PETR4"]
            },
            "description": "Gera análise fundamentalista da Petrobras via LLM.\n\nEspera:\n- verdict: Positivo | Neutro | Negativo\n- score: 0-100\n- disclaimer obrigatório\n- positive_points e negative_points preenchidos"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Estrutura da resposta', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('ticker');",
                  "    pm.expect(body).to.have.property('verdict');",
                  "    pm.expect(body).to.have.property('score');",
                  "    pm.expect(body).to.have.property('confidence_level');",
                  "    pm.expect(body).to.have.property('positive_points');",
                  "    pm.expect(body).to.have.property('negative_points');",
                  "    pm.expect(body).to.have.property('conclusion');",
                  "    pm.expect(body).to.have.property('disclaimer');",
                  "});",
                  "",
                  "pm.test('Disclaimer presente e não vazio', () => {",
                  "    pm.expect(pm.response.json().disclaimer).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Verdict válido', () => {",
                  "    const verdict = pm.response.json().verdict;",
                  "    pm.expect(['Positivo', 'Neutro', 'Negativo']).to.include(verdict);",
                  "});",
                  "",
                  "pm.test('Score entre 0 e 100', () => {",
                  "    const score = pm.response.json().score;",
                  "    pm.expect(score).to.be.within(0, 100);",
                  "});",
                  "",
                  "pm.test('ticker = PETR4', () => {",
                  "    pm.expect(pm.response.json().ticker).to.eql('PETR4');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
