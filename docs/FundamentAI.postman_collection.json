    {
      "name": "Fluxo Completo (E2E)",
      "description": "Sequência que simula o fluxo completo do frontend:\n1. Health check\n2. Busca dados do ticker\n3. Solicita análise LLM\n\nExecutar em ordem.",
      "item": [
        {
          "name": "1. Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API online', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('e2e_ticker', 'WEGE3');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Busca Dados do Ticker",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/ticker/{{e2e_ticker}}",
              "host": ["{{base_url}}"],
              "path": ["api", "ticker", "{{e2e_ticker}}"]
            },
            "description": "Usa o ticker definido no passo anterior via variável de coleção."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Dados do ticker retornados', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('e2e_asset_type', body.asset_type);",
                  "pm.collectionVariables.set('e2e_score', body.score.score);",
                  "console.log('Ticker:', body.ticker, '| Tipo:', body.asset_type, '| Score:', body.score.score);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. Solicita Análise LLM",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/analysis/{{e2e_ticker}}",
              "host": ["{{base_url}}"],
              "path": ["api", "analysis", "{{e2e_ticker}}"]
            },
            "description": "Solicita análise LLM para o ticker do fluxo E2E."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Análise gerada', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Disclaimer presente', () => pm.expect(body.disclaimer).to.not.be.empty);",
                  "pm.test('Verdict válido', () => {",
                  "    pm.expect(['Positivo', 'Neutro', 'Negativo']).to.include(body.verdict);",
                  "});",
                  "console.log('Verdict:', body.verdict, '| Score:', body.score, '| Cached:', body.cached);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
